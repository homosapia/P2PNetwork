{
  "Network": {
    "NodeId": "", // генерируется при первом запуске
    "Port": 5000,
    "Protocol": "http",
    "DnsBootstrap": {
      "SeedDomains": [
        "seed1.yournetwork.com",
        "seed2.yournetwork.com",
        "seed3.yournetwork.com"
      ],
      "FallbackSeeds": [
        "https://fallback1.yournetwork.com:5000",
        "https://fallback2.yournetwork.com:5000"
      ],
      "TimeoutSeconds": 5,
      "MinPeersToStart": 1,
      "MaxParallelLookups": 3
    },
    "PeerPersistence": {
      "FilePath": "peers.json",
      "MaxSavedPeers": 200
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
